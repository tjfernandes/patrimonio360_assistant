APP_ENV=development
API_PREFIX=/api/v1
LOG_LEVEL=INFO
LOG_JSON=true
LOG_JSON_PRETTY=true
LOG_JSON_INDENT=2
LOG_CHAT_MESSAGES=false
LOG_CHAT_STATE_HISTORY=false
DEBUG_EMBEDDINGS=false
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_SCHEME=https
# Leave empty to mirror Indexer behavior (auto true when username/password exist)
OPENSEARCH_USE_SSL=
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_SSL_SHOW_WARN=false

OPENSEARCH_INDEX_ARTIFACT=cultural_heritage_artifacts_v1
OPENSEARCH_INDEX_IMAGE=cultural_heritage_images
OPENSEARCH_INDEX_MUSEUM=cultural_heritage_museums

ARTIFACT_TEXT_EMBEDDING_DIMENSION=1024
ARTIFACT_MULTIMODAL_EMBEDDING_DIMENSION=2048
MUSEUM_TEXT_EMBEDDING_DIMENSION=1024
IMAGE_MULTIMODAL_EMBEDDING_DIMENSION=2048

QWEN_TEXT_EMBEDDING_MODEL_ID=BAAI/bge-m3
QWEN_MULTIMODAL_EMBEDDING_MODEL_ID=Qwen/Qwen3-VL-Embedding-2B
EMBEDDING_PREFER_BF16=true
EMBEDDING_MAX_LENGTH=2048
TEXT_EMBEDDING_BATCH_SIZE=2
MULTIMODAL_TEXT_EMBEDDING_BATCH_SIZE=8
MULTIMODAL_IMAGE_EMBEDDING_BATCH_SIZE=4

LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://amalia.novasearch.org/vlm/chat/completions
LLM_API_KEY=
LLM_MODEL=carminho/AMALIA-9B-50-DPO
LLM_TEMPERATURE_TEXT=0.4
LLM_TEMPERATURE_JSON=0.0
LLM_MAX_TOKENS=0
LLM_TIMEOUT_SECONDS=45

CHAT_HISTORY_WINDOW=8
CHAT_SESSION_TTL_SECONDS=3600
CHAT_ROLLING_SUMMARY_MAX_CHARS=600
CHAT_ENABLE_RAG=true
CHAT_ENABLE_LLM_LEXICAL_QUERY=true
CHAT_ENABLE_STRUCTURED_QUERY_PLANNING=true
CHAT_ANALYTICS_PLANNER_MIN_CONFIDENCE=0.55
CHAT_ANALYTICS_LIST_TOP_K=10
CHAT_USE_QUERY_EMBEDDINGS=true
CHAT_RETRIEVAL_EMBEDDING_ONLY=false
CHAT_RETRIEVAL_CANDIDATES=15
CHAT_RETRIEVAL_TOP_K=5
CHAT_IN_TOUR_BOOST=1.75
CHAT_IMAGE_RETRIEVAL_TOP_K=6
CHAT_IMAGE_ARTIFACT_TOP_K=5
CHAT_IMAGE_DEFAULT_MESSAGE=Analisa a imagem e identifica a peça mais provável no museu.
CHAT_MODEL_DEFAULT_MESSAGE=Analisa este modelo 3D e identifica a peça mais provável no museu.
CHAT_MODEL_FIRST_PASS_VIEWS=3
CHAT_MODEL_TOTAL_VIEWS=5
CHAT_MODEL_LOW_CONFIDENCE_SCORE_THRESHOLD=0.35
CHAT_MODEL_CACHE_SIZE=12
IMAGE_ASSET_ROOT=Images
POI_TOURS_DIR=
MULTIVIEW_WORKER_HOST=127.0.0.1
MULTIVIEW_WORKER_PORT=3101
MULTIVIEW_WORKER_START_TIMEOUT_SECONDS=30
MULTIVIEW_RENDER_SIZE=512
MULTIVIEW_RENDER_BACKGROUND="#FFFFFF"
MULTIVIEW_RENDER_FOV=35
MULTIVIEW_RENDER_DPR=1.0
MULTIVIEW_RENDER_STRATEGY=adaptive
MULTIVIEW_RENDER_OVERSAMPLE=320
MULTIVIEW_RENDER_ORBIT_MARGIN=1.35
MULTIVIEW_RENDER_ENSURE_TOP=true
MULTIVIEW_RENDER_DELAY_MS=8
MULTIVIEW_SAVE_LAST_VIEWS=true
MULTIVIEW_LAST_VIEWS_DIR=tmp/multiview_last_views
