APP_ENV=development
API_PREFIX=/api/v1
BACKEND_LOG_ENABLED=true
BACKEND_LOG_LEVEL=INFO
BACKEND_ACCESS_LOG_ENABLED=true
BACKEND_LOG_HEALTHCHECKS=false
BACKEND_RAG_DEBUG_ENABLED=true
BACKEND_RAG_DEBUG_MAX_CHARS=40000
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_SCHEME=https
# Leave empty to mirror Indexer behavior (auto true when username/password exist)
OPENSEARCH_USE_SSL=
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_SSL_SHOW_WARN=false

OPENSEARCH_INDEX_ARTIFACT=cultural_heritage_artifacts_v1
OPENSEARCH_INDEX_IMAGE=cultural_heritage_images
OPENSEARCH_INDEX_MUSEUM=cultural_heritage_museums

ARTIFACT_TEXT_EMBEDDING_DIMENSION=1024
ARTIFACT_MULTIMODAL_EMBEDDING_DIMENSION=2048
MUSEUM_TEXT_EMBEDDING_DIMENSION=1024
IMAGE_MULTIMODAL_EMBEDDING_DIMENSION=2048

QWEN_TEXT_EMBEDDING_MODEL_ID=BAAI/bge-m3
QWEN_MULTIMODAL_EMBEDDING_MODEL_ID=Qwen/Qwen3-VL-Embedding-2B
# Optional pinned HF revisions (empty = unpinned/current behavior). The v4/8B
# deploy pins the snapshots used by the index rebuild (2026-07-13):
#   text  Qwen/Qwen3-Embedding-8B    -> 1d8ad4ca9b3dd8059ad90a75d4983776a23d44af
#   image Qwen/Qwen3-VL-Embedding-8B -> 2c4565515e0f265c6511776e7193b22c0968ddc7
QWEN_TEXT_EMBEDDING_MODEL_REVISION=
QWEN_MULTIMODAL_EMBEDDING_MODEL_REVISION=
USE_OPENROUTER_BGE_M3=false
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_BGE_MODEL=baai/bge-m3
EMBEDDING_PREFER_BF16=true
EMBEDDING_MAX_LENGTH=2048
TEXT_EMBEDDING_BATCH_SIZE=2
MULTIMODAL_TEXT_EMBEDDING_BATCH_SIZE=8
MULTIMODAL_IMAGE_EMBEDDING_BATCH_SIZE=4

LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://amalia.novasearch.org/vlm/chat/completions
LLM_API_KEY=
LLM_MODEL=carminho/AMALIA-9B-50-DPO
LLM_TEMPERATURE_TEXT=0.4
LLM_TEMPERATURE_JSON=0.0
LLM_MAX_TOKENS=0
LLM_TIMEOUT_SECONDS=45

CHAT_HISTORY_WINDOW=8
CHAT_SESSION_TTL_SECONDS=3600
CHAT_ROLLING_SUMMARY_MAX_CHARS=600
CHAT_ENABLE_RAG=true
CHAT_ENABLE_LLM_LEXICAL_QUERY=true
CHAT_USE_QUERY_EMBEDDINGS=true
CHAT_RETRIEVAL_EMBEDDING_ONLY=false
CHAT_RETRIEVAL_CANDIDATES=15
CHAT_RETRIEVAL_TOP_K=5
CHAT_RETRIEVAL_RESULTS_PAGE_SIZE=10
CHAT_RETRIEVAL_PAGINATION_WINDOW=150
CHAT_IN_TOUR_BOOST=1.75
# Pontos constantes somados a imagens in_tour na pesquisa visual
# (constant_score = desempate previsível; 1.0 sequestrava o ranking).
IMAGE_IN_TOUR_BOOST=0.05

# --- Fase 3: retrieval multimodal de produção (desligado por defeito) ---
# off    -> comportamento atual (sem ramo visual, sem alteração de ranking)
# intent -> texto→imagem apenas quando a intenção visual é identificada
# always -> texto→imagem em todas as pesquisas textuais (avaliação/benchmark)
MULTIMODAL_RETRIEVAL_MODE=off
MULTIMODAL_RRF_K=60
MULTIMODAL_ARTIFACT_WEIGHT=1.0
MULTIMODAL_IMAGE_WEIGHT=0.7
# Floor de score do ramo visual antes da fusão. Calibrado 2026-07-13:
# positivos >= 0.6677, amostra visual >= 0.645, negativos top-1 max 0.712 —
# corta só a cauda fraca; a qualidade vem do router + fusão por ranks.
MULTIMODAL_MIN_IMAGE_SCORE=0.64
MULTIMODAL_IMAGE_TOP_K=30
# Pesos da fusão imagem+texto (i2i é o ramo principal).
MULTIMODAL_I2I_WEIGHT=1.0
MULTIMODAL_IMAGE_TEXT_ARTIFACT_WEIGHT=0.5
# E9: ramos múltiplos via _msearch (fallback automático). E10: margem
# in_tour pós-fusão (0.0 = desligada; sobe no máx. 1 posição).
MULTIMODAL_USE_MSEARCH=true
MULTIMODAL_IN_TOUR_MARGIN=0.0
MULTIMODAL_DEBUG=false
CHAT_IMAGE_RETRIEVAL_TOP_K=6
CHAT_IMAGE_ARTIFACT_TOP_K=5
CHAT_IMAGE_RETRIEVAL_PAGINATION_WINDOW=150
CHAT_IMAGE_DEFAULT_MESSAGE=Analisa a imagem e identifica a peça mais provável no museu.
CHAT_MODEL_DEFAULT_MESSAGE=Analisa este modelo 3D e identifica a peça mais provável no museu.
CHAT_MODEL_FIRST_PASS_VIEWS=3
CHAT_MODEL_TOTAL_VIEWS=5
CHAT_MODEL_LOW_CONFIDENCE_SCORE_THRESHOLD=0.35
CHAT_MODEL_CACHE_SIZE=12
IMAGE_ASSET_ROOT=Images
POI_TOURS_DIR=
MULTIVIEW_WORKER_HOST=127.0.0.1
MULTIVIEW_WORKER_PORT=3101
MULTIVIEW_WORKER_START_TIMEOUT_SECONDS=30
MULTIVIEW_RENDER_SIZE=512
MULTIVIEW_RENDER_BACKGROUND="#FFFFFF"
MULTIVIEW_RENDER_FOV=35
MULTIVIEW_RENDER_DPR=1.0
MULTIVIEW_RENDER_STRATEGY=adaptive
MULTIVIEW_RENDER_OVERSAMPLE=320
MULTIVIEW_RENDER_ORBIT_MARGIN=1.35
MULTIVIEW_RENDER_ENSURE_TOP=true
MULTIVIEW_RENDER_DELAY_MS=8
MULTIVIEW_SAVE_LAST_VIEWS=true
MULTIVIEW_LAST_VIEWS_DIR=tmp/multiview_last_views

QUERY_LOG_ENABLED=true
QUERY_LOG_PATH=logs/evaluation/backend_queries.jsonl
FRONTEND_EVENT_LOG_PATH=logs/evaluation/frontend_events.jsonl

# Reranking de 2a fase (desligado por defeito; modelos 8B pinados por revisao)
CHAT_ENABLE_RERANKING=false
RERANKER_MODEL_ID=Qwen/Qwen3-Reranker-8B
RERANKER_MODEL_REVISION=77d193c791ed757ca307ee72715aa132723da912
RERANKER_MAX_LENGTH=1024
RERANKER_BATCH_SIZE=10
RERANKER_CANDIDATES=24
RERANKER_INSTRUCTION=Given a museum visitor query, retrieve museum artifact records relevant to the query
RERANKER_PREFER_BF16=true
CHAT_ENABLE_VL_RERANKING=false
VL_RERANKER_MODEL_ID=Qwen/Qwen3-VL-Reranker-8B
VL_RERANKER_MODEL_REVISION=b212dc8c91a8164aef1ea2de9c1a867611e75c04
VL_RERANKER_INSTRUCTION=Given a user query (image and/or text), retrieve museum artifact images that match the queried object
VL_RERANKER_BATCH_SIZE=4
VL_RERANKER_CANDIDATES=16
VL_RERANKER_MAX_IMAGE_SIDE=1024
